TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
TELEGRAM_SESSION_NAME=telegram_proxy
TELEGRAM_SESSION_DIR=./data/telegram

# Optional bootstrap path if you already have a Telethon string session.
TELEGRAM_SESSION_STRING=

APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100
DEFAULT_CONTEXT_SIZE=5
MAX_CONTEXT_SIZE=20
TELEGRAM_HISTORY_WAIT_TIME=1.0
TELEGRAM_HISTORY_CONCURRENCY=1
TELEGRAM_FLOOD_SLEEP_THRESHOLD=5
TELEGRAM_ALBUM_WINDOW=24

# Leave disabled for now. The dependency is already wired for later.
API_AUTH_ENABLED=false
API_BEARER_TOKEN=
